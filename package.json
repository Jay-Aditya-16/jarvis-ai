{
  "name": "jarvis-ai",
  "version": "1.0.0",
  "description": "Terminal AI agent with multi-model routing, skills, RAG, web search, and Skill Sentinel security scanning",
  "main": "ai.js",
  "bin": {
    "jarvis": "./ai.js",
    "claw": "./claw.js"
  },
  "scripts": {
    "start": "node ai.js",
    "claw": "node claw.js",
    "server": "node server.js",
    "mcp": "node mcp.js",
    "benchmark": "node benchmark/run.js",
    "benchmark:validate": "node benchmark/validate.js",
    "benchmark:matlab": "${MATLAB_BIN:-/Applications/MATLAB_R2025b.app/bin/matlab} -batch \"run('benchmark/analyze.m')\""
  },
  "keywords": [
    "ai",
    "agent",
    "terminal",
    "cli",
    "openrouter",
    "rag",
    "llm",
    "multi-model"
  ],
  "author": "Jay-Aditya-16",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@xenova/transformers": "^2.17.2",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "express": "^4.21.0",
    "figlet": "^1.11.0",
    "openai": "^6.39.0",
    "ora": "^9.4.0",
    "readline-sync": "^1.4.10",
    "vectra": "^0.15.0",
    "ws": "^8.18.0",
    "zod": "^3.25.0"
  }
}
